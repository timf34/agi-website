---
import { advisors } from '../content';
---

<ul class="council">
  {
    advisors.map((a, i) => (
      <li class="reveal" style={`--reveal-delay:${0.08 + i * 0.08}s`}>
        {a.url ? (
          <a class="advisor" href={a.url} target="_blank" rel="noopener noreferrer">
            <span class="portrait">
              <img src={a.photo} alt={a.name} width="400" height="480" loading="lazy" />
            </span>
            <span class="name">{a.name}</span>
            <span class="title">{a.title}</span>
          </a>
        ) : (
          <div class="advisor">
            <span class="portrait">
              <img src={a.photo} alt={a.name} width="400" height="480" loading="lazy" />
            </span>
            <span class="name">{a.name}</span>
            <span class="title">{a.title}</span>
          </div>
        )}
      </li>
    ))
  }
</ul>

<style>
  .council {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(20px, 2.5vw, 36px);
  }

  .advisor {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-decoration: none;
  }

  .portrait {
    display: block;
    aspect-ratio: 5 / 6;
    overflow: hidden;
    background: var(--pale);
    margin-bottom: 0.65rem;
  }

  .portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1);
  }

  .name {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 420;
    line-height: 1.25;
    color: var(--ink);
  }

  a.advisor:hover .name {
    color: var(--blue);
  }

  .title {
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--slate);
  }

  @media (max-width: 860px) {
    .council {
      grid-template-columns: repeat(2, 1fr);
      gap: 28px 20px;
    }
  }

  @media (max-width: 420px) {
    .name {
      font-size: 1.05rem;
    }

    .title {
      font-size: 0.78rem;
    }
  }
</style>
