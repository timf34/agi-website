---
import { site } from '../content';

interface Props {
  inverse?: boolean;
}

const { inverse = false } = Astro.props;
const year = new Date().getFullYear();
---

<footer class:list={['site-footer', { inverse }]}>
  <div class="container bar">
    <a class="mark" href="/">
      <img src="/logo.png" alt={site.name} width="1648" height="288" />
    </a>
    <a class="mail tlink" href={`mailto:${site.email}`}>{site.email}</a>
    <span class="legal">© {year} · Supported by <a class="tlink" href="https://bluedot.org/">Bluedot</a></span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--hairline);
    padding-block: clamp(28px, 4vw, 44px);
  }

  .bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px 32px;
  }

  .mark {
    display: block;
    line-height: 0;
  }

  .mark img {
    height: 26px;
    width: auto;
  }

  .mail {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--blue);
  }

  .legal {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--slate);
  }

  .inverse {
    border-top-color: var(--hairline-inverse);
  }

  /* black source PNG → white on dark backgrounds */
  .inverse .mark img {
    filter: brightness(0) invert(1);
  }

  .inverse .mail {
    color: rgba(247, 249, 252, 0.8);
  }

  .inverse .legal {
    color: rgba(247, 249, 252, 0.45);
  }
</style>
