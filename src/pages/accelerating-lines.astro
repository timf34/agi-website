---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ContactCTA from '../components/ContactCTA.astro';
import AdvisoryCouncil from '../components/AdvisoryCouncil.astro';
import { site, hero, about, whyNow, format, participants } from '../content';
---

<Base title={`${site.name} — Accelerating Lines`}>
  <div class="dark-hero-wrap">
    <SiteHeader inverse />

    <main id="main">
      <!-- HERO -->
      <section class="hero">
        <svg
          class="lines lines--desktop draw"
          viewBox="0 0 1440 800"
          preserveAspectRatio="none"
          fill="none"
          aria-hidden="true"
        >
          <g class="flow">
            <path pathLength="1" d="M0,40 C700,40 980,325 1440,325" style="--draw-delay:0s" />
            <path pathLength="1" d="M0,105 C700,105 980,339 1440,339" style="--draw-delay:.05s" />
            <path pathLength="1" d="M0,171 C700,171 980,352 1440,352" style="--draw-delay:.1s" />
            <path pathLength="1" d="M0,236 C700,236 980,366 1440,366" style="--draw-delay:.15s" />
            <path pathLength="1" d="M0,302 C700,302 980,380 1440,380" style="--draw-delay:.2s" />
            <path pathLength="1" d="M0,367 C700,367 980,393 1440,393" style="--draw-delay:.25s" />
            <path
              class="accent"
              pathLength="1"
              d="M0,433 C700,433 980,407 1440,407"
              style="--draw-delay:.3s"
            />
            <path pathLength="1" d="M0,498 C700,498 980,420 1440,420" style="--draw-delay:.35s" />
            <path pathLength="1" d="M0,564 C700,564 980,434 1440,434" style="--draw-delay:.4s" />
            <path pathLength="1" d="M0,629 C700,629 980,448 1440,448" style="--draw-delay:.45s" />
            <path pathLength="1" d="M0,695 C700,695 980,461 1440,461" style="--draw-delay:.5s" />
            <path pathLength="1" d="M0,760 C700,760 980,475 1440,475" style="--draw-delay:.55s" />
          </g>
          <g class="ticks">
            <line pathLength="1" x1="180" y1="772" x2="180" y2="758" style="--draw-delay:.8s" />
            <line pathLength="1" x1="520" y1="772" x2="520" y2="758" style="--draw-delay:.86s" />
            <line pathLength="1" x1="731" y1="772" x2="731" y2="758" style="--draw-delay:.92s" />
            <line pathLength="1" x1="861" y1="772" x2="861" y2="758" style="--draw-delay:.98s" />
            <line pathLength="1" x1="943" y1="772" x2="943" y2="758" style="--draw-delay:1.04s" />
            <line pathLength="1" x1="993" y1="772" x2="993" y2="758" style="--draw-delay:1.1s" />
            <line pathLength="1" x1="1024" y1="772" x2="1024" y2="758" style="--draw-delay:1.16s" />
            <line pathLength="1" x1="1043" y1="772" x2="1043" y2="758" style="--draw-delay:1.22s" />
          </g>
        </svg>

        <!-- mobile: strictly horizontal lines; spacing compresses to convey acceleration.
             The coloured underline is anchored to the headline itself (see .hero h1::after). -->
        <svg
          class="lines lines--mobile draw"
          viewBox="0 0 390 844"
          preserveAspectRatio="none"
          fill="none"
          aria-hidden="true"
        >
          <g class="flow">
            <line pathLength="1" x1="0" y1="70" x2="390" y2="70" style="--draw-delay:0s" />
            <line pathLength="1" x1="0" y1="170" x2="390" y2="170" style="--draw-delay:.05s" />
            <line pathLength="1" x1="0" y1="258" x2="390" y2="258" style="--draw-delay:.1s" />
            <line pathLength="1" x1="0" y1="334" x2="390" y2="334" style="--draw-delay:.15s" />
            <line pathLength="1" x1="0" y1="398" x2="390" y2="398" style="--draw-delay:.2s" />
            <line pathLength="1" x1="0" y1="512" x2="390" y2="512" style="--draw-delay:.25s" />
            <line pathLength="1" x1="0" y1="556" x2="390" y2="556" style="--draw-delay:.3s" />
            <line pathLength="1" x1="0" y1="620" x2="390" y2="620" style="--draw-delay:.35s" />
            <line pathLength="1" x1="0" y1="704" x2="390" y2="704" style="--draw-delay:.4s" />
            <line pathLength="1" x1="0" y1="798" x2="390" y2="798" style="--draw-delay:.45s" />
          </g>
          <g class="ticks">
            <line pathLength="1" x1="40" y1="836" x2="40" y2="822" style="--draw-delay:.8s" />
            <line pathLength="1" x1="140" y1="836" x2="140" y2="822" style="--draw-delay:.86s" />
            <line pathLength="1" x1="215" y1="836" x2="215" y2="822" style="--draw-delay:.92s" />
            <line pathLength="1" x1="268" y1="836" x2="268" y2="822" style="--draw-delay:.98s" />
            <line pathLength="1" x1="305" y1="836" x2="305" y2="822" style="--draw-delay:1.04s" />
            <line pathLength="1" x1="330" y1="836" x2="330" y2="822" style="--draw-delay:1.1s" />
            <line pathLength="1" x1="346" y1="836" x2="346" y2="822" style="--draw-delay:1.16s" />
            <line pathLength="1" x1="356" y1="836" x2="356" y2="822" style="--draw-delay:1.22s" />
          </g>
        </svg>
        <div class="scrim" aria-hidden="true"></div>

        <div class="container hero-inner">
          <h1 class="display reveal">{hero.headline}</h1>
          <p class="hero-sub reveal" style="--reveal-delay:.12s">{hero.sub}</p>
          <p class="reveal" style="--reveal-delay:.24s">
            <a class="btn btn--inverse" href="#initiative">
              Explore the initiative <span class="arrow" aria-hidden="true">↓</span>
            </a>
          </p>
        </div>
      </section>
    </main>
  </div>

  <!-- LIGHT EDITORIAL BODY -->
  <section class="section" id="initiative">
    <div class="container two-col">
      <p class="eyebrow eyebrow--muted reveal">{about.eyebrow}</p>
      <div>
        <h2 class="statement reveal" style="--reveal-delay:.1s">{about.statement}</h2>
        <p class="body-copy reveal" style="--reveal-delay:.2s">{about.body}</p>
      </div>
    </div>
  </section>

  <section class="section hairline-top" id="why-now">
    <div class="container two-col">
      <p class="eyebrow eyebrow--muted reveal">{whyNow.eyebrow}</p>
      <div>
        <h2 class="statement reveal" style="--reveal-delay:.1s">{whyNow.statement}</h2>
        <p class="body-copy reveal" style="--reveal-delay:.2s">{whyNow.body}</p>
      </div>
    </div>
  </section>

  <section class="section hairline-top" id="format">
    <div class="container two-col">
      <p class="eyebrow eyebrow--muted reveal">The Exercise</p>
      <div class="steps">
        {
          format.map((step, i) => (
            <div class="step reveal" style={`--reveal-delay:${0.1 + i * 0.12}s`}>
              <span class="step-num">0{i + 1}</span>
              <h3 class="step-title">{step.label}</h3>
              <p class="body-copy">{step.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section hairline-top" id="participants">
    <div class="container two-col">
      <p class="eyebrow eyebrow--muted reveal">Around the Table</p>
      <p class="statement participants reveal" style="--reveal-delay:.1s">
        {participants.join(' · ')}
      </p>
    </div>
  </section>

  <section class="section hairline-top" id="advisory-council">
    <div class="container two-col">
      <p class="eyebrow eyebrow--muted reveal">Advisory Council</p>
      <AdvisoryCouncil />
    </div>
  </section>

  <!-- CTA on navy, echoing the hero -->
  <section class="section cta-panel" id="contact">
    <div class="container">
      <ContactCTA inverse />
    </div>
  </section>

  <SiteFooter />
</Base>

<style>
  .dark-hero-wrap {
    background: var(--navy);
    color: var(--paper-cool);
  }

  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .lines--mobile {
    display: none;
  }

  /* the stretched desktop geometry turns diagonal on tall/narrow viewports:
     switch on orientation, not width, so portrait tablets are covered too */
  @media (orientation: portrait), (max-width: 760px) {
    .lines--desktop {
      display: none;
    }

    .lines--mobile {
      display: block;
    }

    /* the coloured line is anchored to the headline itself: a full-bleed,
       perfectly horizontal underline that draws in after the text reveals */
    .hero .display {
      position: relative;
    }

    .hero .display::after {
      content: '';
      position: absolute;
      left: calc(50% - 50vw);
      width: 100vw;
      bottom: -0.42em;
      height: 1.5px;
      background: linear-gradient(
        90deg,
        rgba(122, 162, 247, 0),
        rgba(122, 162, 247, 0.85) 7%,
        rgba(122, 162, 247, 0.85) 93%,
        rgba(122, 162, 247, 0)
      );
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 1.2s var(--ease-draw) 0.5s;
    }

    .hero .display.is-inview::after {
      transform: scaleX(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero .display::after {
      transform: scaleX(1);
      transition: none;
    }
  }

  .lines .flow path {
    stroke: rgba(247, 249, 252, 0.16);
    stroke-width: 1;
  }

  .lines .flow path:nth-child(odd) {
    stroke: rgba(247, 249, 252, 0.09);
  }

  .lines .flow path.accent {
    stroke: rgba(122, 162, 247, 0.75);
    stroke-width: 1.4;
  }

  .lines .ticks line {
    stroke: rgba(247, 249, 252, 0.35);
    stroke-width: 1;
  }

  /* feather the left edge so lines emerge from the dark */
  .scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, var(--navy) 0%, rgba(11, 27, 51, 0) 32%),
      linear-gradient(180deg, rgba(11, 27, 51, 0.9) 0%, rgba(11, 27, 51, 0) 22%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
    padding-block: 130px 80px;
  }

  .hero .display {
    max-width: 15ch;
    color: var(--white);
  }

  .hero-sub {
    max-width: 34rem;
    font-size: 1.05rem;
    color: rgba(247, 249, 252, 0.72);
  }

  /* editorial body */
  .two-col {
    display: grid;
    grid-template-columns: minmax(140px, 220px) 1fr;
    gap: clamp(24px, 5vw, 80px);
    align-items: start;
  }

  .statement {
    max-width: 30ch;
    margin-bottom: 1.4rem;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 3.5vw, 48px);
  }

  .step {
    border-top: 1px solid var(--hairline-strong);
    padding-top: 1.2rem;
  }

  .step-num {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--cobalt);
    letter-spacing: 0.12em;
  }

  .step-title {
    font-size: 1.35rem;
    margin: 0.6rem 0 0.5rem;
  }

  .participants {
    color: var(--blue);
    margin-bottom: 0;
  }

  .cta-panel {
    background: var(--navy);
    color: var(--paper-cool);
  }

  @media (max-width: 760px) {
    .two-col {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>
