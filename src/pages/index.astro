---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ContactCTA from '../components/ContactCTA.astro';
import AdvisoryCouncil from '../components/AdvisoryCouncil.astro';
import { site, hero, about, whyNow, format, participants } from '../content';
---

<Base title={`${site.name} — Preparing leaders for an age of advanced AI`}>
  <div class="dark-hero-wrap">
    <SiteHeader inverse />

    <main id="main">
      <!-- HERO -->
      <section class="hero">
        <!-- flow lines are generated at runtime from the hero's real dimensions,
             converging into a band centred on the headline underline -->
        <svg class="lines" fill="none" aria-hidden="true"></svg>
        <div class="scrim" aria-hidden="true"></div>

        <div class="container hero-inner">
          <h1 class="display reveal">{hero.headline}</h1>
          <p class="hero-sub reveal" style="--reveal-delay:.12s">{hero.sub}</p>
          <p class="reveal" style="--reveal-delay:.24s">
            <a class="btn btn--inverse" href="#initiative">
              Explore the initiative <span class="arrow" aria-hidden="true">↓</span>
            </a>
          </p>
        </div>
      </section>
    </main>
  </div>

  <!-- LIGHT EDITORIAL BODY -->
  <section class="section" id="initiative">
    <div class="container two-col">
      <p class="eyebrow eyebrow--muted reveal">{about.eyebrow}</p>
      <div>
        <h2 class="statement reveal" style="--reveal-delay:.1s">{about.statement}</h2>
        <p class="body-copy reveal" style="--reveal-delay:.2s">{about.body}</p>
      </div>
    </div>
  </section>

  <section class="section hairline-top" id="why-now">
    <div class="container two-col">
      <p class="eyebrow eyebrow--muted reveal">{whyNow.eyebrow}</p>
      <div>
        <h2 class="statement reveal" style="--reveal-delay:.1s">{whyNow.statement}</h2>
        <p class="body-copy reveal" style="--reveal-delay:.2s">{whyNow.body}</p>
      </div>
    </div>
  </section>

  <section class="section hairline-top" id="format">
    <div class="container two-col">
      <p class="eyebrow eyebrow--muted reveal">The Exercise</p>
      <div class="steps">
        {
          format.map((step, i) => (
            <div class="step reveal" style={`--reveal-delay:${0.1 + i * 0.12}s`}>
              <span class="step-num">0{i + 1}</span>
              <h3 class="step-title">{step.label}</h3>
              <p class="body-copy">{step.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section hairline-top" id="participants">
    <div class="container two-col">
      <p class="eyebrow eyebrow--muted reveal">Around the Table</p>
      <p class="statement participants reveal" style="--reveal-delay:.1s">
        {participants.join(' · ')}
      </p>
    </div>
  </section>

  <section class="section hairline-top" id="advisory-council">
    <div class="container two-col">
      <p class="eyebrow eyebrow--muted reveal">Advisory Council</p>
      <AdvisoryCouncil />
    </div>
  </section>

  <!-- CTA on navy, echoing the hero -->
  <section class="section cta-panel" id="contact">
    <div class="container">
      <ContactCTA inverse />
    </div>
  </section>

  <SiteFooter />
</Base>

<script>
  // Accelerating lines, generated from the hero's real dimensions.
  // Geometry mirrors the original hand-drawn version (1440x800):
  // evenly spread entry points, a calm first half, then a synchronized sweep
  // into a tight convergence band. The bend and band both adapt to width so
  // the acceleration remains legible in portrait instead of flattening out.
  // The band is centred on the headline underline so the fan pours into it.
  const NS = 'http://www.w3.org/2000/svg';
  const hero = document.querySelector('.hero') as HTMLElement;
  const svg = hero?.querySelector('.lines') as SVGSVGElement | null;
  const h1 = hero?.querySelector('.display') as HTMLElement | null;

  function layoutBottom(element: HTMLElement, ancestor: HTMLElement) {
    let bottom = element.offsetTop + element.offsetHeight;
    let parent = element.offsetParent as HTMLElement | null;

    while (parent && parent !== ancestor) {
      bottom += parent.offsetTop;
      parent = parent.offsetParent as HTMLElement | null;
    }

    return bottom;
  }

  function buildLines() {
    if (!hero || !svg || !h1) return;
    const w = hero.clientWidth;
    const h = hero.clientHeight;
    svg.setAttribute('viewBox', `0 0 ${w} ${h}`);

    // Use layout coordinates so the headline's 24px reveal transform is never
    // baked into the line position, then leave a small optical underline gap.
    const fs = parseFloat(getComputedStyle(h1).fontSize);
    const underlineGap = Math.min(Math.max(fs * 0.1, 4), 7);
    const yc = layoutBottom(h1, hero) + underlineGap;

    // Narrow canvases need a later, stronger sweep: a broad entry fan still
    // collapses into a compact band, but the curves stay calm behind the copy.
    const widthT = Math.min(Math.max((w - 390) / (1200 - 390), 0), 1);
    const spreadRatio = 0.92 + (0.85 - 0.92) * widthT;
    const bandRatio = 0.3 + (0.2 - 0.3) * widthT;
    const c1Ratio = 0.55 + (0.48 - 0.55) * widthT;
    const c2Ratio = 0.82 + (0.7 - 0.82) * widthT;
    const spread = spreadRatio * h;
    const band = spread * bandRatio;
    const c1 = (c1Ratio * w).toFixed(0);
    const c2 = (c2Ratio * w).toFixed(0);

    svg.innerHTML = '';
    const flow = document.createElementNS(NS, 'g');
    flow.setAttribute('class', 'flow');
    // odd count: the middle line sits exactly at the underline height —
    // horizontal, full-width, and part of the fan like the original accent
    const N = 13;
    const mid = (N - 1) / 2;
    for (let i = 0; i < N; i++) {
      const t = i / (N - 1);
      const yL = Math.min(Math.max(yc + (t - 0.5) * spread, 0.04 * h), 0.97 * h).toFixed(1);
      const yR = (yc + (t - 0.5) * band).toFixed(1);
      const p = document.createElementNS(NS, 'path');
      p.setAttribute('d', `M0,${yL} C${c1},${yL} ${c2},${yR} ${w},${yR}`);
      p.setAttribute('pathLength', '1');
      p.style.setProperty('--draw-delay', `${(i * 0.05).toFixed(2)}s`);
      if (i === mid) p.setAttribute('class', 'accent');
      flow.appendChild(p);
    }
    svg.appendChild(flow);

    // tick ruler: gaps halve toward the right — time compressing
    const ticks = document.createElementNS(NS, 'g');
    ticks.setAttribute('class', 'ticks');
    let x = 0.125 * w;
    let gap = 0.236 * w;
    let k = 0;
    while (gap > 0.013 * w && x < w) {
      const l = document.createElementNS(NS, 'line');
      l.setAttribute('x1', x.toFixed(0));
      l.setAttribute('x2', x.toFixed(0));
      l.setAttribute('y1', (h - 28).toFixed(0));
      l.setAttribute('y2', (h - 42).toFixed(0));
      l.setAttribute('pathLength', '1');
      l.style.setProperty('--draw-delay', `${(0.8 + k * 0.06).toFixed(2)}s`);
      ticks.appendChild(l);
      x += gap;
      gap *= 0.62;
      k++;
    }
    svg.appendChild(ticks);
  }

  if (svg) {
    buildLines();
    svg.classList.add('draw');
    // force initial (hidden) state to paint, then trigger the draw-in
    requestAnimationFrame(() => requestAnimationFrame(() => svg.classList.add('is-inview')));
    document.fonts?.ready.then(buildLines);
    let rt: ReturnType<typeof setTimeout>;
    addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(buildLines, 150);
    });
  }
</script>

<style>
  .dark-hero-wrap {
    background: var(--navy);
    color: var(--paper-cool);
  }

  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .lines--mobile {
    display: none;
  }

  /* portrait: lines stay visible — brighter strokes, lighter feather */
  @media (orientation: portrait), (max-width: 760px) {
    .lines :global(.flow path) {
      stroke: rgba(247, 249, 252, 0.24);
    }

    .lines :global(.flow path:nth-child(odd)) {
      stroke: rgba(247, 249, 252, 0.14);
    }

  }

  .lines :global(.flow path) {
    stroke: rgba(247, 249, 252, 0.16);
    stroke-width: 1;
  }

  .lines :global(.flow path:nth-child(odd)) {
    stroke: rgba(247, 249, 252, 0.09);
  }

  .lines :global(.flow path.accent) {
    stroke: rgba(122, 162, 247, 0.92);
    stroke-width: 1.5;
    filter: drop-shadow(0 0 4px rgba(82, 128, 230, 0.28));
  }

  .lines :global(.ticks line) {
    stroke: rgba(247, 249, 252, 0.35);
    stroke-width: 1;
  }


  /* feather the left edge so lines emerge from the dark */
  .scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, var(--navy) 0%, rgba(11, 27, 51, 0) 32%),
      linear-gradient(180deg, rgba(11, 27, 51, 0.9) 0%, rgba(11, 27, 51, 0) 22%);
    pointer-events: none;
  }

  /* Preserve the desktop fade's visual distance on a narrower canvas. This
     must follow the base rule so the mobile gradient wins the cascade. */
  @media (orientation: portrait), (max-width: 760px) {
    .scrim {
      background:
        linear-gradient(90deg, var(--navy) 0%, rgba(11, 27, 51, 0) 58%),
        linear-gradient(180deg, rgba(11, 27, 51, 0.9) 0%, rgba(11, 27, 51, 0) 18%);
    }
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
    padding-block: 130px 80px;
  }

  .hero .display {
    max-width: 15ch;
    color: var(--white);
  }

  .hero-sub {
    max-width: 34rem;
    font-size: 1.05rem;
    color: rgba(247, 249, 252, 0.72);
  }

  /* editorial body */
  .two-col {
    display: grid;
    grid-template-columns: minmax(140px, 220px) 1fr;
    gap: clamp(24px, 5vw, 80px);
    align-items: start;
  }

  .statement {
    max-width: 30ch;
    margin-bottom: 1.4rem;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 3.5vw, 48px);
  }

  .step {
    border-top: 1px solid var(--hairline-strong);
    padding-top: 1.2rem;
  }

  .step-num {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--cobalt);
    letter-spacing: 0.12em;
  }

  .step-title {
    font-size: 1.35rem;
    margin: 0.6rem 0 0.5rem;
  }

  .participants {
    color: var(--blue);
    margin-bottom: 0;
  }

  .cta-panel {
    background: var(--navy);
    color: var(--paper-cool);
  }

  @media (max-width: 760px) {
    .two-col {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>
